{
  "name": "nxspub",
  "version": "0.9.1",
  "description": "Automated release tool tailored for modern multi-branch workflows.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.12.3"
  },
  "packageManager": "pnpm@9.12.3",
  "type": "module",
  "types": "dist/index.d.mts",
  "bin": {
    "nxspub": "bin/nxspub.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "postinstall.mjs"
  ],
  "scripts": {
    "start": "tsx ./src/cli.ts",
    "build": "tsdown && pnpm console:web:build",
    "console:web:dev": "vite --config src/console/web/vite.config.mjs",
    "console:web:build": "vite build --config src/console/web/vite.config.mjs",
    "docs:dev": "pnpm --dir docs-site dev",
    "docs:dev:fast": "pnpm --dir docs-site dev:fast",
    "docs:build": "pnpm --dir docs-site build",
    "test": "tsdown && vitest",
    "check": "tsc --incremental --noEmit",
    "lint": "eslint --cache .",
    "format": "prettier --write --cache .",
    "format-check": "prettier --check --cache .",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node ./postinstall.mjs",
    "console": "pnpm console:web:build && pnpm run start console --web --open",
    "changelog": "tsx scripts/changelog.ts",
    "version": "pnpm run start version",
    "release": "pnpm run start release"
  },
  "nxspub": {
    "git-hooks": {
      "pre-commit": "pnpm lint-staged && pnpm check"
    }
  },
  "lint-staged": {
    "*.{js,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "cac": "^7.0.0",
    "chalk": "^5.6.2",
    "defu": "^6.1.7",
    "detect-indent": "^7.0.2",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.2",
    "h3": "^1.15.4",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.1",
    "semver-es": "^0.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.15",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.1.0",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.4.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.14",
    "tsdown": "^0.21.7",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vite": "^7.1.12",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "nxspub",
    "monorepo",
    "workspace",
    "versioning",
    "changelog",
    "independent-mode",
    "locked-mode",
    "topological-propagation",
    "conventional-commits",
    "release-automation",
    "publish-workflow",
    "git-hooks",
    "semver"
  ],
  "author": "nyxsola",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nxsjs/nxspub.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nxsjs/nxspub/issues"
  },
  "homepage": "https://github.com/nxsjs/nxspub#readme"
}
